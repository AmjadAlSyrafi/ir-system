# ── Ports ──────────────────────────────────────────────
API_GATEWAY_PORT=8000
PREPROCESSING_PORT=8001
INDEXING_PORT=8002
RETRIEVAL_PORT=8003
QUERY_REFINEMENT_PORT=8004
EVALUATION_PORT=8005

# ── Internal service URLs (used by api_gateway) ────────
PREPROCESSING_URL=http://preprocessing:8001
INDEXING_URL=http://indexing:8002
RETRIEVAL_URL=http://retrieval:8003
QUERY_REFINEMENT_URL=http://query_refinement:8004
EVALUATION_URL=http://evaluation:8005

# ── Data paths ─────────────────────────────────────────
INDEX_DIR=/data/indexes
DATASET_DIR=/data/datasets

# ── Model settings ─────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
DEFAULT_RETRIEVAL_MODEL=hybrid
BM25_K1=1.5
BM25_B=0.75

# ── Hybrid model weights ───────────────────────────────
TFIDF_WEIGHT=0.2
BM25_WEIGHT=0.3
EMBEDDING_WEIGHT=0.5

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=info
