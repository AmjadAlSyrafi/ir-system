        {
          "name": "Evaluate Single Model",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model_name\": \"bm25\",\n  \"k\": 10,\n  \"qrels\": [\n    {\"query_id\": \"q1\", \"doc_id\": \"d1\", \"relevance\": 1},\n    {\"query_id\": \"q1\", \"doc_id\": \"d3\", \"relevance\": 1},\n    {\"query_id\": \"q2\", \"doc_id\": \"d2\", \"relevance\": 2},\n    {\"query_id\": \"q2\", \"doc_id\": \"d4\", \"relevance\": 1},\n    {\"query_id\": \"q3\", \"doc_id\": \"d5\", \"relevance\": 1},\n    {\"query_id\": \"q3\", \"doc_id\": \"d6\", \"relevance\": 1}\n  ],\n  \"results_per_query\": {\n    \"q1\": [\n      {\"doc_id\": \"d1\", \"score\": 0.92, \"rank\": 1},\n      {\"doc_id\": \"d2\", \"score\": 0.81, \"rank\": 2},\n      {\"doc_id\": \"d3\", \"score\": 0.74, \"rank\": 3},\n      {\"doc_id\": \"d4\", \"score\": 0.60, \"rank\": 4}\n    ],\n    \"q2\": [\n      {\"doc_id\": \"d2\", \"score\": 0.88, \"rank\": 1},\n      {\"doc_id\": \"d5\", \"score\": 0.61, \"rank\": 2},\n      {\"doc_id\": \"d4\", \"score\": 0.55, \"rank\": 3}\n    ],\n    \"q3\": [\n      {\"doc_id\": \"d7\", \"score\": 0.70, \"rank\": 1},\n      {\"doc_id\": \"d5\", \"score\": 0.65, \"rank\": 2},\n      {\"doc_id\": \"d6\", \"score\": 0.58, \"rank\": 3}\n    ]\n  }\n}",
