            "body": {
              "mode": "raw",
              "raw": "{\n  \"doc_id\": \"doc001\",\n  \"text\": \"Information retrieval systems retrieve relevant documents from large text collections using ranking algorithms like BM25 and TF-IDF.\"\n}",
              "options": { "raw": { "language": "json" } }
