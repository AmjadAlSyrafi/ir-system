{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "IR Search Engine",
    "description": "Complete API test collection for the Information Retrieval System.\n\nServices:\n- API Gateway      → http://localhost:8000\n- Preprocessing    → http://localhost:8001\n- Indexing         → http://localhost:8002\n- Retrieval        → http://localhost:8003\n- Query Refinement → http://localhost:8005\n- Evaluation       → http://localhost:8006\n\nImport the companion environment file 'IR_System.postman_environment.json' first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [

    {
      "name": "🌐 API Gateway  :8000",
      "description": "Central entry point — orchestrates all services.",
      "item": [

        {
          "name": "Health — All Services",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/health",
              "host": ["{{gateway_url}}"],
              "path": ["health"]
            },
            "description": "Pings every downstream service and returns their status. Overall status is 'ok' only if all services are healthy."
          },
          "response": []
        },

        {
          "name": "List Datasets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/datasets",
              "host": ["{{gateway_url}}"],
              "path": ["datasets"]
            },
            "description": "Returns available datasets: dataset1 (MS MARCO) and dataset2 (NQ)."
          },
          "response": []
        },

        {
          "name": "List Models",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/models",
              "host": ["{{gateway_url}}"],
              "path": ["models"]
            },
            "description": "Returns all supported retrieval models."
          },
          "response": []
        },

        {
          "name": "Search — BM25",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"information retrieval ranking algorithms\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"bm25\",\n  \"top_k\": 10,\n  \"use_refinement\": true,\n  \"user_id\": \"user1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "BM25 search with query refinement enabled on MS MARCO dataset."
          },
          "response": []
        },

        {
          "name": "Search — BM25 Custom k1 & b",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"document retrieval scoring\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"bm25\",\n  \"top_k\": 10,\n  \"use_refinement\": false,\n  \"bm25_k1\": 2.0,\n  \"bm25_b\": 0.5\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "BM25 with custom k1=2.0 (higher term freq saturation) and b=0.5 (reduced length normalization)."
          },
          "response": []
        },

        {
          "name": "Search — TF-IDF",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"vector space model cosine similarity\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"tfidf\",\n  \"top_k\": 10,\n  \"use_refinement\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "TF-IDF Vector Space Model search on MS MARCO."
          },
          "response": []
        },

        {
          "name": "Search — BERT Embeddings",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"how do search engines work\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"embedding\",\n  \"top_k\": 10,\n  \"use_refinement\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "Dense semantic search using sentence-transformers + FAISS."
          },
          "response": []
        },

        {
          "name": "Search — Hybrid Parallel (RRF Fusion)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"passage retrieval benchmark evaluation\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"hybrid_parallel\",\n  \"top_k\": 10,\n  \"use_refinement\": true,\n  \"user_id\": \"user1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "BM25 + TF-IDF + Embedding results fused with Reciprocal Rank Fusion."
          },
          "response": []
        },

        {
          "name": "Search — Hybrid Serial (BM25 → Re-rank)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"natural language question answering\",\n  \"dataset\": \"dataset2\",\n  \"model\": \"hybrid_serial\",\n  \"top_k\": 10,\n  \"use_refinement\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "Two-stage pipeline: BM25 fetches 100 candidates, embeddings re-rank them. Uses NQ dataset."
          },
          "response": []
        },

        {
          "name": "Search — Dataset 2 (NQ)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"who invented the telephone\",\n  \"dataset\": \"dataset2\",\n  \"model\": \"bm25\",\n  \"top_k\": 5,\n  \"use_refinement\": true,\n  \"user_id\": \"user1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "BM25 search on the Natural Questions dataset."
          },
          "response": []
        },

        {
          "name": "Build Index for Dataset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dataset\": \"dataset1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/index/build",
              "host": ["{{gateway_url}}"],
              "path": ["index", "build"]
            },
            "description": "Triggers the indexing service to build all indexes for the given dataset."
          },
          "response": []
        },

        {
          "name": "Evaluate Model",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"model_name\": \"bm25_gateway_test\",\n  \"dataset\": \"dataset1\",\n  \"k\": 10,\n  \"qrels\": [\n    {\"query_id\": \"q1\", \"doc_id\": \"d1\", \"relevance\": 1},\n    {\"query_id\": \"q1\", \"doc_id\": \"d3\", \"relevance\": 1},\n    {\"query_id\": \"q2\", \"doc_id\": \"d2\", \"relevance\": 2},\n    {\"query_id\": \"q2\", \"doc_id\": \"d4\", \"relevance\": 1}\n  ],\n  \"results_per_query\": {\n    \"q1\": [\n      {\"doc_id\": \"d1\", \"score\": 0.92, \"rank\": 1},\n      {\"doc_id\": \"d2\", \"score\": 0.81, \"rank\": 2},\n      {\"doc_id\": \"d3\", \"score\": 0.74, \"rank\": 3}\n    ],\n    \"q2\": [\n      {\"doc_id\": \"d2\", \"score\": 0.88, \"rank\": 1},\n      {\"doc_id\": \"d5\", \"score\": 0.61, \"rank\": 2},\n      {\"doc_id\": \"d4\", \"score\": 0.55, \"rank\": 3}\n    ]\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/evaluate",
              "host": ["{{gateway_url}}"],
              "path": ["evaluate"]
            },
            "description": "Run evaluation metrics (MAP, Recall, P@k, nDCG@k) via the gateway."
          },
          "response": []
        }

      ]
    },

