    {
      "name": "🔁 End-to-End Flow",
      "description": "Run these requests in order (1→2→3→4) to simulate a complete search session.",
      "item": [

        {
          "name": "1. Preprocess Query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query_text\": \"What are the best ranking algorithms for document retrieval?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{preprocessing_url}}/preprocess/query",
              "host": ["{{preprocessing_url}}"],
              "path": ["preprocess", "query"]
            },
            "description": "Step 1: Tokenise and clean the raw query."
          },
          "response": []
        },

        {
          "name": "2. Refine Query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What are the best ranking algorithms for document retrieval?\",\n  \"user_id\": \"demo_user\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{refinement_url}}/refine",
              "host": ["{{refinement_url}}"],
              "path": ["refine"]
            },
            "description": "Step 2: Apply spell correction, synonym expansion, history boosting."
          },
          "response": []
        },

        {
          "name": "3. Search with BM25 (via Gateway)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What are the best ranking algorithms for document retrieval?\",\n  \"dataset\": \"dataset1\",\n  \"model\": \"bm25\",\n  \"top_k\": 10,\n  \"use_refinement\": true,\n  \"user_id\": \"demo_user\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{gateway_url}}/search",
              "host": ["{{gateway_url}}"],
              "path": ["search"]
            },
            "description": "Step 3: Full pipeline search — gateway calls refinement + preprocessing + retrieval internally."
          },
          "response": []
        },

        {
          "name": "4. Evaluate Results",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
