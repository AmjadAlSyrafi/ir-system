          "response": []
        },

        {
          "name": "Preprocess Query",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query_text\": \"How do search engines rank and retrieve documents?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{preprocessing_url}}/preprocess/query",
              "host": ["{{preprocessing_url}}"],
              "path": ["preprocess", "query"]
            },
            "description": "Returns original query, token list, and processed_text."
