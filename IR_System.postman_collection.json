          "response": []
        },

        {
          "name": "Preprocess Batch (3 Documents)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documents\": [\n    {\n      \"doc_id\": \"d1\",\n      \"text\": \"BM25 is a probabilistic retrieval function based on term frequency and inverse document frequency.\"\n    },\n    {\n      \"doc_id\": \"d2\",\n      \"text\": \"TF-IDF measures how important a word is to a document in a collection or corpus.\"\n    },\n    {\n      \"doc_id\": \"d3\",\n      \"text\": \"Dense retrieval uses neural networks to encode queries and documents into dense vector representations.\"\n    }\n  ],\n  \"n_jobs\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{preprocessing_url}}/preprocess/batch",
              "host": ["{{preprocessing_url}}"],
              "path": ["preprocess", "batch"]
            },
            "description": "Preprocesses multiple documents in parallel. n_jobs=-1 uses all CPU cores."
          },
          "response": []
        },

        {
          "name": "Preprocess Batch (n_jobs = -1, Parallel)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documents\": [\n    {\"doc_id\": \"d1\", \"text\": \"Inverted index stores a mapping from terms to the documents containing them.\"},\n    {\"doc_id\": \"d2\", \"text\": \"Precision measures the fraction of retrieved documents that are relevant.\"},\n    {\"doc_id\": \"d3\", \"text\": \"Recall measures the fraction of relevant documents that were retrieved.\"},\n    {\"doc_id\": \"d4\", \"text\": \"NDCG normalizes the discounted cumulative gain by the ideal ranking.\"},\n    {\"doc_id\": \"d5\", \"text\": \"Mean average precision averages precision over all recall levels.\"}\n  ],\n  \"n_jobs\": -1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{preprocessing_url}}/preprocess/batch",
              "host": ["{{preprocessing_url}}"],
              "path": ["preprocess", "batch"]
            },
            "description": "Parallel batch preprocessing using all available CPU cores."
          },
          "response": []
        }

      ]
    },

